{
  "version": 6,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Ninja Release (std::embed clang)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "fetch",
      "displayName": "Ninja Release + compile-time fetches",
      "inherits": "default",
      "cacheVariables": {
        "CTBROWSER_EXAMPLES_FETCH": "ON"
      }
    },
    {
      "name": "windows",
      "displayName": "Windows x86_64 cross (llvm-mingw std::embed)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-windows",
      "toolchainFile": "${sourceDir}/cmake/toolchain-windows-x86_64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CTBROWSER_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "windows-fetch",
      "displayName": "Windows cross + compile-time fetches",
      "inherits": "windows",
      "cacheVariables": {
        "CTBROWSER_EXAMPLES_FETCH": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "fetch",
      "configurePreset": "fetch"
    },
    {
      "name": "windows",
      "configurePreset": "windows"
    },
    {
      "name": "windows-fetch",
      "configurePreset": "windows-fetch"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "fetch",
      "configurePreset": "fetch",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
